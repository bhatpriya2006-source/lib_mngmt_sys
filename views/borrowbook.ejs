<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Books</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="main-page">
        <h1>Books Management</h1>
        <a href="/borrowbook/borrownew">borrow new book</a>

        <table>
            <tr>
                <th>ID</th>
                <th>USN</th>
                <th>BOOK_ID</th>
                <th>BOOK_DATE</th>
                <th>RETURN_DATE</th>
                <th>STATUS</th>
                <th>ACTIONS</th>
            </tr>
            <% borrowbook.forEach(book => { %>
                <tr>
                    <td><%= book.ID %></td>
                    <td><%= book.USN %></td>
                    <td><%= book.BOOK_ID %></td>
                    <td><%= book.BOOK_DATE %></td>
                    <td><%= book.RETURN_DATE %></td>
                    <td><%= book.STATUS %></td>
                    <td>
                        <a href="/borrowbook/edit/<%= book.ID %>">edit</a>
                        <a href="/borrowbook/delete/<%= book.ID %>">delete</a>
                    </td>
                </tr>

            <% }) %>
        </table>
    </div>
    
</body>
</html>